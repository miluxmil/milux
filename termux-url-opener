def download_spotify(url):
    """Download from Spotify."""
    song_dir = config["spotify_path"]
    os.makedirs(song_dir, exist_ok=True)
    
    try:
        subprocess.run(["spotifydl", url, "-o", song_dir], check=True)
        exit_success()
    except subprocess.CalledProcessError as e:
        logging.error(f"Spotify download failed: {e}")
        print(f"{R}Error al descargar desde Spotify.{RE}")

def download_youtube(url):
    """Download from YouTube."""
    formats_file = Path.home() / ".milux" / "formats.mlx"
    
    print(f"{G}Obteniendo formatos...{RE}")
    spin()
    try:
        subprocess.run(["yt-dlp", "-F", url], stdout=formats_file.open('w'), check=True)
    except subprocess.CalledProcessError as e:
        logging.error(f"Failed to fetch YouTube formats: {e}")
        print(f"{R}Error al obtener formatos de YouTube.{RE}")
        return
    
    formats()
    print(f"{G}[{Y}!{G}] {RE}SI TODAS LAS OPCIONES ES: [ NO DISPONIBLE ] REINTENTA{RE}")
    
    # Check if running in interactive mode
    if sys.stdin.isatty():
        option = input(f"{G}-Milux- >> {RE}").strip()
    else:
        # Default to MP3 if not interactive
        option = "1"
        print(f"{G}Modo no interactivo: Descargando en MP3 por defecto.{RE}")
    
    if option.lower() == "u":
        buscar_ultima_version(url)
        return
    elif option.lower() == "x":
        sys.exit(0)
    elif option.lower() == "a":
        acerca_de(url)
        return
    elif option.lower() == "f":
        reparar_script(url)
        return
    elif option == "1":
        # MP3 download logic
        output_path = "/data/data/com.termux/files/home/storage/shared/Youtube/%(title)s.%(ext)s"
        try:
            subprocess.run(["yt-dlp", "--extract-audio", "--audio-format", "mp3", "--output", output_path, url], check=True)
            print(f"{G}Descarga en MP3 completada.{RE}")
            # Suggest conversion if converter is installed
            suggest_conversion(output_path)
        except subprocess.CalledProcessError as e:
            logging.error(f"MP3 download failed: {e}")
            print(f"{R}Error al descargar en MP3.{RE}")
    elif option in ["2", "3", "4", "5", "6", "7", "8"]:
        # Video download logic
        resolution_map = {
            "2": "240",
            "3": "360",
            "4": "480",
            "5": "720",
            "6": "1080",
            "7": "1440",
            "8": "2160"
        }
        resolution = resolution_map[option]
        print(f"{G}Descargando en {resolution}p...{RE}")
        output_path = "/data/data/com.termux/files/home/storage/shared/Youtube/%(title)s.%(ext)s"
        try:
            subprocess.run(["yt-dlp", "-f", f"bestvideo[height<={resolution}]+bestaudio/best[height<={resolution}]", "--output", output_path, url], check=True)
            print(f"{G}Descarga en {resolution}p completada.{RE}")
            # Suggest conversion if converter is installed
            suggest_conversion(output_path)
        except subprocess.CalledProcessError as e:
            logging.error(f"Video download failed: {e}")
            print(f"{R}Error al descargar en {resolution}p.{RE}")
    else:
        print(f"{R}Opción no válida.{RE}")

def download_dailymotion(url):
    """Download from Dailymotion."""
    try:
        result = subprocess.run(["youtube-dl", "-F", url], capture_output=True, text=True, check=True)
        print(result.stdout)
        
        # Parse formats and prompt user
        formats = result.stdout.splitlines()
        options = {}
        for line in formats:
            if "1080" in line:
                options["1"] = line.split()[0]
            elif "720" in line:
                options["2"] = line.split()[0]
            elif "480" in line:
                options["3"] = line.split()[0]
            elif "380" in line:
                options["4"] = line.split()[0]
            elif "240" in line:
                options["5"] = line.split()[0]
        
        for key, value in options.items():
            print(f"{G}[{RE}{key}{G}] {Y}Video calidad {value}{RE}")
        
        choice = input(f"{G}Selecciona una opción >> {RE}").strip()
        if choice in options:
            subprocess.run(["youtube-dl", "-f", options[choice], url], check=True)
            print(f"{G}Listo!{RE}")
            input("Presiona Enter para continuar...")
    except subprocess.CalledProcessError as e:
        logging.error(f"Dailymotion download failed: {e}")
        print(f"{R}Error al descargar desde Dailymotion.{RE}")

def buscar_ultima_version(url):
