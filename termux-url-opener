def reparar_script(url):
    """Reparar el script y sus dependencias."""
    logo()
    print(f"{G}Iniciando proceso de reparación...{RE}")
    
    # Verificar y reinstalar dependencias
    print(f"{G}Verificando dependencias...{RE}")
    dependencies = ["wget", "yt-dlp", "spotifydl", "youtube-dl"]
    for dep in dependencies:
        if not check_dependency(dep):
            print(f"{Y}Reinstalando {dep}...{RE}")
            install_dependency(dep)
        else:
            print(f"{G}{dep} ya está instalado.{RE}")
    
    # Verificar permisos del script
    script_path = "/data/data/com.termux/files/home/bin/termux-url-opener"
    if not os.access(script_path, os.X_OK):
        print(f"{Y}Corrigiendo permisos del script...{RE}")
        os.chmod(script_path, 0o755)
        print(f"{G}Permisos corregidos.{RE}")
    else:
        print(f"{G}Permisos del script son correctos.{RE}")
    
    # Restablecer configuración si es necesario
    config_path = "/data/data/com.termux/files/home/.milux/config.json"
    if not os.path.exists(config_path):
        print(f"{Y}Restableciendo configuración...{RE}")
        load_config()
        print(f"{G}Configuración restablecida.{RE}")
    else:
        print(f"{G}Configuración existe y parece correcta.{RE}")
    
    print(f"{G}Proceso de reparación completado.{RE}")
    input(f"{G}Presiona Enter para continuar...{RE}")
    mostrar_menu_principal(url)

def download_tiktok(url):
    """Download from TikTok."""
    try:
        subprocess.run(["youtube-dl", "-f", "0", url], check=True)
        exit_success()
    except subprocess.CalledProcessError as e:
        logging.error(f"TikTok download failed: {e}")
        print(f"{R}Error al descargar desde TikTok.{RE}")

def suggest_conversion(file_path):
    """Suggest converting the downloaded file if converter is installed."""
    if check_dependency("converter"):
        # Check if running in interactive mode
        if sys.stdin.isatty():
            print(f"{G}¿Deseas convertir el archivo ahora? (s/n){RE}")
            choice = input().strip().lower()
            if choice == "s":
                try:
                    # Find the most recently downloaded file
                    download_dir = "/data/data/com.termux/files/home/storage/shared/Youtube"
                    files = sorted(Path(download_dir).glob("*.*"), key=os.path.getmtime, reverse=True)
                    if files:
                        latest_file = files[0]
                        subprocess.run(["converter", str(latest_file)], check=True)
                        print(f"{G}Archivo convertido con éxito.{RE}")
                    else:
                        print(f"{R}No se encontraron archivos para convertir.{RE}")
                except subprocess.CalledProcessError as e:
                    logging.error(f"Conversion failed: {e}")
                    print(f"{R}Error al convertir el archivo.{RE}")
        else:
            print(f"{G}Modo no interactivo: Omitiendo sugerencia de conversión.{RE}")

def main():
    """Main function."""
    if len(sys.argv) < 2:
        print(f"{R}Usage: {sys.argv[0]} <URL>{RE}")
        sys.exit(1)
    
    url = sys.argv[1]
    
    if url == "--install":
        # Install dependencies
        dependencies = ["wget", "yt-dlp", "spotifydl"]
        for dep in dependencies:
            if not check_dependency(dep):
                print(f"{G}Installing {dep}...{RE}")
                install_dependency(dep)
        
        # Download and run installer
        try:
            subprocess.run(["wget", "https://raw.githubusercontent.com/miluxmil/milux/master/installer", "-O", "installer"], check=True)
            subprocess.run(["bash", "installer"], check=True)
            os.remove("installer")
        except subprocess.CalledProcessError as e:
            logging.error(f"Installation failed: {e}")
            print(f"{R}Error durante la instalación.{RE}")
        return
    
    if url == "--reparar":
        reparar_script()
        return
    
    if url == "--buscar-version":
        buscar_ultima_version()
        return
    
    if url == "--acerca-de":
        acerca_de()
        return
    
    logo()
    
    if "open.spotify.com" in url:
        download_spotify(url)
    elif "youtu.be" in url or "youtube.com" in url:
        download_youtube(url)
    elif "dailymotion.com" in url:
        download_dailymotion(url)
    elif "vm.tiktok.com" in url:
        download_tiktok(url)
    else:
        print(f"{R}URL no soportada.{RE}")

if __name__ == "__main__":
    main()
