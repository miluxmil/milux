    try:
        # Descargar el script original para comparar versiones
        print(f"{G}Descargando información de la última versión...{RE}")
        subprocess.run(["wget", "https://raw.githubusercontent.com/miluxmil/milux/master/bin/termux-url-opener", "-O", "latest_version"], check=True)
        
        # Leer la versión del script original
        with open("latest_version", "r") as f:
            for line in f:
                if "VA=" in line:
                    latest_version = line.split("=")[1].strip().strip('"')
                    break
        
        current_version = config["version"]
        
        if latest_version > current_version:
            print(f"{G}¡Hay una nueva versión disponible!{RE}")
            print(f"{Y}Versión actual:{RE} {current_version}")
            print(f"{Y}Última versión:{RE} {latest_version}")
            print(f"{G}Descargando la última versión...{RE}")
            
            # Descargar y reemplazar el script
            subprocess.run(["wget", "https://raw.githubusercontent.com/miluxmil/milux/master/bin/termux-url-opener", "-O", "/data/data/com.termux/files/home/bin/termux-url-opener"], check=True)
            os.chmod("/data/data/com.termux/files/home/bin/termux-url-opener", 0o755)
            
            print(f"{G}¡Actualización completada!{RE}")
        else:
            print(f"{G}Ya tienes la última versión.{RE}")
            print(f"{Y}Versión actual:{RE} {current_version}")
        
        # Limpiar el archivo temporal
        os.remove("latest_version")
    except subprocess.CalledProcessError as e:
        logging.error(f"Failed to check for updates: {e}")
        print(f"{R}No se pudo conectar al repositorio para buscar actualizaciones.{RE}")
        print(f"{Y}Verifica tu conexión a Internet y vuelve a intentarlo.{RE}")
    
    input(f"{G}Presiona Enter para continuar...{RE}")
    mostrar_menu_principal(url)

